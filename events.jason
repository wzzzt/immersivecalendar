        "en": "Drift"
      },
      "start": "2026-07-14",
      "eind": "2026-08-31",
      "maker": "Merel uit de Machine & VPRO Medialab",
      "duur": "Volgt het ritme van de maan",
      "handig": "Gratis · English spoken",
      "logline": {
        "nl": "Een generatieve audio-ervaring over zeespiegelstijging en AI — een podcast die geen podcast is.",
        "en": "A generative audio experience about rising sea levels and AI — a podcast that is not a podcast."
      },
      "beschrijving": {
        "nl": "Drift koppelt de zeespiegelstijging en klimaatcrisis aan de opkomst van AI in een generatieve audio-ervaring. De verhaalwereld combineert verbeelding met feitelijke bronnen zoals realtimeweersvoorspellingen van het KNMI.",
        "en": "Drift links rising sea levels and the climate crisis to the rise of AI in a generative audio experience. The story world combines imagination with factual sources including real-time weather forecasts from KNMI."
      },
      "stad": "Online",
      "locatie": "In je podcast app",
      "types": [
        "Audio driven immersion",
        "Generatief"
      ],
      "foto": "/images/drift-cover-v2.png",
