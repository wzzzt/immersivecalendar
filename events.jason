    {
      "naam": {
        "nl": "Synthetic Halo",
        "en": "Synthetic Halo"
      },
      "start": "2026-03-18",
      "eind": "2026-10-11",
      "maker": "Kurina Sohn",
      "duur": "10 min",
      "handig": "Gratis",
      "logline": {
        "nl": "Ervaar de Halo Machine. Je hersenactiviteit wordt gemeten en vertaald naar een unieke soundscape.",
        "en": "Experience the Halo Machine. Your brain activity is measured and translated into a unique soundscape."
      },
      "beschrijving": {
        "nl": "Synthetic Halo onderzoekt de vraag of verlichting — een staat die traditioneel wordt bereikt door langdurige meditatie — kan worden waargenomen, gemeten en gedeeld. Kurina gebruikt AI en innovatieve technologie om individuele hersengolven om te zetten in een veranderende geluids- en beeldervaring, gebaseerd op 3D-scans en geluidsopnames uit Odaesan National Park en Woljeongsa-tempel in Zuid-Korea.",
        "en": "Synthetic Halo explores whether enlightenment — a state traditionally achieved through prolonged meditation — can be perceived, measured and shared. Kurina uses AI and innovative technology to translate individual brainwaves into a shifting sound and image experience, based on 3D scans and field recordings from Odaesan National Park and Woljeongsa Temple in South Korea."
      },
      "stad": "Enschede",
      "locatie": "Tetem",
      "types": [
        "Immersieve installaties",
        "AI-driven"
      ],
      "foto": "/images/synthetichalo.png",
      "link": "https://tetem.nl/event/synthetic-halo/",
      "uitgelicht": false,
      "verseTip": true
    },
    {
      "naam": {
        "nl": "Before the Story Starts",
        "en": "Before the Story Starts"
      },
      "start": "2026-06-12",
      "eind": "2026-10-31",
      "maker": "Urland",
      "duur": "90 min",
      "handig": "Vanaf 12+",
      "logline": {
        "nl": "Een experimentele, immersieve one-man performance op de drempel voordat een verhaal begint.",
        "en": "An experimental, immersive one-man performance on the threshold before a story begins."
      },
      "beschrijving": {
        "nl": "This is not the start of the story, we haven't started yet. What do you need to know? Before we start? We don't know why. We can guess, but we don't know. We never will. The elusive Why.",
        "en": "This is not the start of the story, we haven't started yet. What do you need to know? Before we start? We don't know why. We can guess, but we don't know. We never will. The elusive Why."
      },
      "stad": "Meerdere locaties",
      "locatie": "Oerol, Nijmegen, Bergen op Zoom, Amsterdam, Den Haag, Den Bosch",
      "types": [
        "Performatief",
        "Audio driven immersion"
      ],
      "foto": "/images/urlandstorybeginsv2.png",
      "link": "https://urland.nl/project/before-the-story-starts",
      "uitgelicht": false,
      "verseTip": false
    },
