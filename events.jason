    {
      "naam": {
        "nl": "Begin Again",
        "en": "Begin Again"
      },
      "start": "2026-10-22",
      "eind": "2027-01-29",
      "maker": "BrotherTill & Lisa Weeda",
      "duur": null,
      "handig": null,
      "logline": {
        "nl": "In een tijd waarin het nut van de mens ter discussie staat, pleit een moeder voor een wereld zonder ego. Haar zoon houdt halsstarrig vast aan een wereld mét ego.",
        "en": "In a time when the usefulness of humankind is up for debate, a mother pleads for a world without ego. Her son stubbornly clings to a world with ego."
      },
      "beschrijving": {
        "nl": "In de zintuiglijke, muzikale voorstelling BEGIN AGAIN zoeken prijswinnend interdisciplinair kunstcollectief BrotherTill en schrijver Lisa Weeda opnieuw de grenzen van het theater op. Bij binnenkomst krijgt iedereen een steen mee. Wat volgt is een wervelend afscheid: een mix van hypertechnologie, meeslepende muziek en een intens menselijke beleving. Het publiek bevindt zich midden in het verhaal. De zaal zoemt. De stenen zingen: bevrijd ons.",
        "en": "In the sensory, musical performance BEGIN AGAIN, award-winning interdisciplinary art collective BrotherTill and writer Lisa Weeda once again push the boundaries of theatre. Upon entry, everyone receives a stone. What follows is a whirling farewell: a mix of hypertechnology, immersive music and an intensely human experience. The audience stands right in the middle of the story."
      },
      "stad": "Verschillende steden",
      "locatie": "Tournee",
      "types": [
        "Immersief theater"
      ],
      "foto": "/images/beginagain.jpg",
      "link": "https://www.brothertill.nl/projects/begin-again/",
      "uitgelicht": false,
      "verseTip": false
    },
    {
      "naam": {
        "nl": "Amsterdam 1652",
        "en": "Amsterdam 1652"
      },
      "start": "2026-05-21",
      "eind": "2028-12-31",
      "maker": "Nienke Huitenga Broeren & ENTR",
      "duur": "45 min",
      "handig": "Vanaf 8+ · NL en EN",
      "logline": {
        "nl": "Loop samen door het Amsterdam van de 17e eeuw, gezien door de ogen van een gewone Amsterdammer. Zie het IJ, de Dam en de nieuwe brugh en ontdek hoe mensen leefden, werkten en samenkwamen.",
        "en": "Walk together through 17th-century Amsterdam through the eyes of an ordinary Amsterdammer. See the IJ, the Dam and the nieuwe brugh, and discover how people lived, worked and came together."
      },
      "beschrijving": {
        "nl": "De ervaring is ontworpen om samen te beleven. Bezoekers bewegen gelijktijdig door dezelfde virtuele wereld en maken samen de reis door de stad. Zo ontstaat een gedeelde ervaring waarin je niet alleen naar geschiedenis kijkt, maar er middenin staat.",
        "en": "The experience is designed to be shared. Visitors move simultaneously through the same virtual world, making the journey through the city together — not just observing history, but standing right in the middle of it."
      },
      "stad": "Amsterdam",
      "locatie": "ENTR",
      "types": [
        "XR"
      ],
      "foto": "/images/kade.jpeg",
      "link": "https://entrmuseum.com/",
      "uitgelicht": false,
      "verseTip": false
    }
