      "uitgelicht": false,
      "verseTip": false
    },
    {
      "naam": {
        "nl": "Pioneers of Media Art",
        "en": "Pioneers of Media Art"
      },
      "start": "2026-06-10",
      "eind": "2026-09-10",
      "maker": "Verschillende makers",
      "duur": "60 min",
      "handig": "Ontmoet de klassiekers",
      "logline": {
        "nl": "Hoe verandert kunst wanneer een nieuw medium opduikt? En wat gebeurt er wanneer kunstenaars de grenzen van dat medium verleggen?",
        "en": "How does art change when a new medium emerges? And what happens when artists push the boundaries of that medium?"
      },
      "beschrijving": {
        "nl": "Deze tentoonstelling neemt je mee op een reis door 10 ruimtes — die elk onderzoeken hoe generaties kunstenaars de grenzen van kunst, technologie en ervaring hebben verlegd. Van early video art tot AI-gedreven installaties.",
        "en": "This exhibition takes you on a journey through 10 spaces — each exploring how generations of artists have pushed the boundaries of art, technology and experience. From early video art to AI-driven installations."
      },
      "stad": "Amsterdam",
      "locatie": "NXT Museum",
      "types": [
        "Tentoonstelling",
        "Media Art History"
      ],
      "foto": "/images/pioneers.jpg",
      "link": "https://nxtmuseum.com/exhibition/pioneers-of-media-art",
      "uitgelicht": false,
      "verseTip": false
    },
