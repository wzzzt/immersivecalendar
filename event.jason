    {
      "naam": {
        "nl": "Amsterdam 1652",
        "en": "Amsterdam 1652"
      },
      "start": "2026-05-21",
      "eind": "2028-12-31",
      "maker": "Nienke Huitenga Broeren & ENTR",
      "duur": "45 min",
      "handig": "Vanaf 8+ · NL en EN",
      "logline": {
        "nl": "Loop samen door het Amsterdam van de 17e eeuw, gezien door de ogen van een gewone Amsterdammer. Zie het IJ, de Dam en de nieuwe brugh en ontdek hoe mensen leefden, werkten en samenkwamen.",
        "en": "Walk together through 17th-century Amsterdam through the eyes of an ordinary Amsterdammer. See the IJ, the Dam and the nieuwe brugh, and discover how people lived, worked and came together."
      },
      "beschrijving": {
        "nl": "De ervaring is ontworpen om samen te beleven. Bezoekers bewegen gelijktijdig door dezelfde virtuele wereld en maken samen de reis door de stad. Zo ontstaat een gedeelde ervaring waarin je niet alleen naar geschiedenis kijkt, maar er middenin staat.",
        "en": "The experience is designed to be shared. Visitors move simultaneously through the same virtual world, making the journey through the city together — not just observing history, but standing right in the middle of it."
      },
      "stad": "Amsterdam",
      "locatie": "ENTR",
      "types": [
        "XR"
      ],
      "foto": "/images/kade.jpeg",
      "link": "https://entrmuseum.com/",
      "uitgelicht": false,
      "verseTip": false
    }
