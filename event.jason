    {
      "naam": {
        "nl": "William Forsythe – Choreographic Objects",
        "en": "William Forsythe – Choreographic Objects"
      },
      "start": "2026-06-06",
      "eind": "2026-08-23",
      "maker": "William Forsythe",
      "duur": "Take your time",
      "handig": "Interactie gestimuleerd, niet verplicht",
      "logline": {
        "nl": "De wereldberoemde choreograaf William Forsythe nodigt je uit om niet alleen te kijken, maar vooral te doen — elk object schept een situatie waarin beweging de belangrijkste manier is om het werk te ervaren.",
        "en": "World-renowned choreographer William Forsythe invites you not just to look, but above all to act — each object creates a situation in which movement is the primary way to experience the work."
      },
      "beschrijving": {
        "nl": "'Het lichaam is een denkend instrument', aldus William Forsythe. Zijn Choreographic Objects vormen een reeks stellingen: elk object vormt een situatie waarin beweging de belangrijkste manier is om het te ervaren. Bij Voorlinden nodigt Forsythe je uit om te experimenteren, te reageren en te ontdekken hoe je lichaam door middel van beweging denkt.",
        "en": "'The body is a thinking instrument', says William Forsythe. His Choreographic Objects form a series of propositions: each object creates a situation in which movement is the primary way to experience it. At Voorlinden, Forsythe invites you to experiment, respond and discover how your body thinks through movement."
      },
      "stad": "Wassenaar",
      "locatie": "Voorlinden",
      "types": [
        "Immersieve installaties",
        "Interactief",
        "Tentoonstelling"
      ],
      "foto": "/images/voorlindenforsythe.jpg",
      "link": "https://www.voorlinden.nl/tentoonstelling/william-forsythe/",
      "uitgelicht": true,
      "verseTip": false
    },
    {
      "naam": {
        "nl": "Drift",
        "en": "Drift"
      },
      "start": "2026-07-14",
      "eind": "2026-08-31",
      "maker": "Merel uit de Machine & VPRO Medialab",
      "duur": "Volgt het ritme van de maan",
      "handig": "Gratis · English spoken",
      "logline": {
        "nl": "Een generatieve audio-ervaring over zeespiegelstijging en AI — een podcast die geen podcast is.",
        "en": "A generative audio experience about rising sea levels and AI — a podcast that is not a podcast."
      },
      "beschrijving": {
        "nl": "Drift koppelt de zeespiegelstijging en klimaatcrisis aan de opkomst van AI in een generatieve audio-ervaring. De verhaalwereld combineert verbeelding met feitelijke bronnen zoals realtimeweersvoorspellingen van het KNMI.",
        "en": "Drift links rising sea levels and the climate crisis to the rise of AI in a generative audio experience. The story world combines imagination with factual sources including real-time weather forecasts from KNMI."
      },
      "stad": "Online",
      "locatie": "In je podcast app",
      "types": [
        "Audio driven immersion",
        "Generatief"
      ],
      "foto": "/images/drift-cover-v2.png",
      "link": "https://www.merel.club/drift/",
      "uitgelicht": false,
      "verseTip": false
    },
    {
      "naam": {
        "nl": "Pioneers of Media Art",
        "en": "Pioneers of Media Art"
      },
      "start": "2026-06-10",
      "eind": "2026-09-10",
      "maker": "Verschillende makers",
      "duur": "60 min",
      "handig": "Ontmoet de klassiekers",
      "logline": {
        "nl": "Hoe verandert kunst wanneer een nieuw medium opduikt? En wat gebeurt er wanneer kunstenaars de grenzen van dat medium verleggen?",
        "en": "How does art change when a new medium emerges? And what happens when artists push the boundaries of that medium?"
      },
      "beschrijving": {
        "nl": "Deze tentoonstelling neemt je mee op een reis door 10 ruimtes — die elk onderzoeken hoe generaties kunstenaars de grenzen van kunst, technologie en ervaring hebben verlegd. Van early video art tot AI-gedreven installaties.",
        "en": "This exhibition takes you on a journey through 10 spaces — each exploring how generations of artists have pushed the boundaries of art, technology and experience. From early video art to AI-driven installations."
      },
      "stad": "Amsterdam",
      "locatie": "NXT Museum",
      "types": [
        "Tentoonstelling",
        "Media Art History"
      ],
      "foto": "/images/pioneers.jpg",
      "link": "https://nxtmuseum.com/exhibition/pioneers-of-media-art",
      "uitgelicht": false,
      "verseTip": false
    },
