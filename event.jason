    {
      "naam": {
        "nl": "Traversing the Mist",
        "en": "Traversing the Mist"
      },
      "start": "2026-07-12",
      "eind": "2026-07-27",
      "maker": "CHOU Tung-yen",
      "duur": "35 min",
      "handig": "Vanaf 16+",
      "logline": {
        "nl": "In een surreëel gay-saunacomplex vind je jezelf belichaamd in het lichaam van een jonge Taiwanese man — geweven door verlangens, opwinding en angsten.",
        "en": "Inside a surreal gay sauna, you find yourself embodied in the body of a young Taiwanese man — woven by desires, excitements, and fears."
      },
      "beschrijving": {
        "nl": "Terwijl je elke verdieping, gang en kamer doorloopt, valt elke laag van het labyrint onomkeerbaar uiteen. Wereldpremière IDFA DocLAB 2023, Grand Prize NewImages Paris.",
        "en": "As you walk along every floor, corridor and room, each layer irreversibly unravels. World première IDFA DocLAB 2023, Grand Prize NewImages Paris."
      },
      "stad": "Amsterdam",
      "locatie": "Podium Mozaïek",
      "types": [
