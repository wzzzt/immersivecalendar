    {
      "naam": {
        "nl": "Opstand",
        "en": "Opstand"
      },
      "start": "2026-07-12",
      "eind": "2026-07-13",
      "maker": "Marte Boneschansker",
      "duur": "60 min",
      "handig": "Nederlands gesproken",
      "logline": {
        "nl": "Een theatrale audio-voorstelling en collectieve oefening in verzet. Ontdek de rebel in jezelf.",
        "en": "A theatrical audio performance and collective exercise in resistance. Discover the rebel in yourself."
      },
      "beschrijving": {
        "nl": "Van massademonstraties tot klein, stil protest: verzet is onderdeel van ons menszijn. OPSTAND is een hoopvolle poging het stille midden in beweging te krijgen. Wie vormt de tegenkracht? Wanneer zeg jij nee? Je hébt invloed. Het heeft zin.",
        "en": "From mass demonstrations to quiet protest: resistance is part of being human. OPSTAND is a hopeful attempt to get the silent majority moving. Who forms the counterforce? When do you say no? You have influence. It matters."
      },
      "stad": "Utrecht",
      "locatie": "Stadsschouwburg Utrecht",
      "types": [
        "Immersief theater",
        "Performatief",
        "Spatial",
        "Audio driven immersion"
      ],
      "foto": "/images/opstand.jpg",
      "link": "https://stadsschouwburg-utrecht.nl/agenda/seizoen-2025-2026/opstand-company-marte-boneschansker",
      "uitgelicht": false,
      "verseTip": false
    },
